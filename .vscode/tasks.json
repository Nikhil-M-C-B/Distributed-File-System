{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build All",
            "type": "shell",
            "command": "make",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "Clean",
            "type": "shell",
            "command": "make clean",
            "problemMatcher": []
        },
        {
            "label": "Rebuild",
            "type": "shell",
            "command": "make clean && make",
            "group": "build",
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "Run Server",
            "type": "shell",
            "command": "./bin/server",
            "isBackground": true,
            "problemMatcher": []
        },
        {
            "label": "Run Client",
            "type": "shell",
            "command": "./bin/client",
            "problemMatcher": []
        }
    ]
}
